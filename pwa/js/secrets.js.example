// Token API AROME Prévision Immédiate (nowcasting 0–6h)
CONFIG.METEO_FRANCE.tokenAromePi = 'VOTRE_TOKEN_AROME_PI_ICI';

// Token API PAAROME (prévisions post-processées jusqu'à +42h)
CONFIG.METEO_FRANCE.tokenPaArome = 'VOTRE_TOKEN_PAAROME_ICI';
