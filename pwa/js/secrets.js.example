// Token API AROME — prévisions +42h (runs toutes les 3h)
CONFIG.METEO_FRANCE.token = 'VOTRE_TOKEN_AROME_ICI';

// Token API AROME-PI — nowcasting 0–6h, pas de 15 min
CONFIG.METEO_FRANCE.tokenAromePi = 'VOTRE_TOKEN_AROMEPI_ICI';

// Token API PAAROME — analyse AROME, conditions actuelles (échéances 0h et 1h)
CONFIG.METEO_FRANCE.tokenPaArome = 'VOTRE_TOKEN_PAAROME_ICI';
